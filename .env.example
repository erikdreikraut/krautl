# Kopieren nach .env und mit echten Werten füllen.
# .env NIEMALS ins Git-Repo committen (siehe .gitignore).

# --- Datenbank ---
DATABASE_URL=postgresql+asyncpg://krautl:changeme@localhost:5432/krautl

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- IMAP-Postfächer (je Postfach ein eigener Block) ---
IMAP_INFO_HOST=imap.deinserver.de
IMAP_INFO_USER=info@dreikraut.de
IMAP_INFO_PASSWORD=

IMAP_SERVICE_HOST=imap.deinserver.de
IMAP_SERVICE_USER=service@dreikraut.de
IMAP_SERVICE_PASSWORD=

IMAP_EINKAUF_HOST=imap.deinserver.de
IMAP_EINKAUF_USER=einkauf@dreikraut.de
IMAP_EINKAUF_PASSWORD=

IMAP_MARKETING_HOST=imap.deinserver.de
IMAP_MARKETING_USER=marketing@dreikraut.de
IMAP_MARKETING_PASSWORD=

# erik@dreikraut.de ist als Zielpostfach in der Klassifikationstabelle
# vorgesehen (Rechnungen, Bewerbungen), wird aber aktuell bewusst NICHT
# eingebunden. Ohne diesen Block bleiben so klassifizierte Mails einfach im
# Ursprungspostfach liegen (siehe worker.py) statt automatisch verschoben zu
# werden.
# IMAP_ERIK_HOST=imap.deinserver.de
# IMAP_ERIK_USER=erik@dreikraut.de
# IMAP_ERIK_PASSWORD=

# --- Cloud-Speicher für Anhänge ---
DROPBOX_ACCESS_TOKEN=

# --- Web-Oberfläche ---
KRAUTL_ADMIN_TOKEN=

# --- Reverse Proxy / TLS ---
# Öffentliche Domain für die Krautl-Oberfläche, z. B. krautl.dreikraut.de.
# Caddy holt sich damit automatisch ein Let's-Encrypt-Zertifikat. Leer lassen
# für einen ersten Test ohne eigene Domain (dann nur per http://<server-ip>).
KRAUTL_DOMAIN=
